# ---------------------------------------------------------------------------
# Ledger — environment
#
# Copy to .env and fill in. .env is gitignored; this file must never hold a
# real value.
#
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ----------------------------------------------
# Pooled connection string — used by the app at runtime.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/ledger?sslmode=require"

# Direct (unpooled) connection — used by `prisma migrate`, which issues DDL and
# must not go through a pooler. On Neon this is the same host without `-pooler`.
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/ledger?sslmode=require"

# --- Stripe (TEST MODE ONLY) ------------------------------------------------
# From https://dashboard.stripe.com/test/apikeys
# The app refuses to boot unless this starts with `sk_test_`.
STRIPE_SECRET_KEY="sk_test_..."

# From `stripe listen` (local) or the webhook endpoint's signing secret in the
# Stripe dashboard (deployed). These differ — a local secret will not verify
# production events.
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- App --------------------------------------------------------------------
# Absolute origin. Used to build Stripe's success/cancel return URLs, so it must
# match where the app actually runs.
APP_URL="http://localhost:3000"

# Signs the visitor session cookie and the admin cookie (HMAC-SHA256).
# Generate:  openssl rand -base64 32
SESSION_SECRET="replace-me-with-at-least-32-random-characters"

# Gates /admin (refunds). Minimum 8 characters.
ADMIN_PASSWORD="choose-a-strong-password"
