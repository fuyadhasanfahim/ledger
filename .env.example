# ---------------------------------------------------------------------------
# Ledger — environment
#
#   cp .env.example .env
#
# .env is gitignored. This file must never hold a real value.
# ---------------------------------------------------------------------------

# --- Database (MongoDB Atlas) ----------------------------------------------
# Any MongoDB works, but the idempotency guard needs its unique indexes built:
#   npm run db:indexes
MONGODB_URI="mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/ledger?retryWrites=true&w=majority"

# --- Stripe (TEST MODE ONLY) ------------------------------------------------
# https://dashboard.stripe.com/test/apikeys
# The app refuses to boot unless these are test keys.
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# From `npm run stripe:listen` (local) or the endpoint's signing secret in the
# Stripe dashboard (deployed). These are DIFFERENT secrets — a local one will
# not verify production events.
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- App --------------------------------------------------------------------
# Absolute origin. Stripe's return URLs are built from it, so it must match
# where the app actually runs.
APP_URL="http://localhost:3000"

# Signs the visitor session cookie and the admin cookie (HMAC-SHA256).
# Generate:  openssl rand -base64 32
SESSION_SECRET="replace-me-with-at-least-32-random-characters"

# Gates /admin (refunds). Minimum 8 characters.
ADMIN_PASSWORD="choose-a-strong-password"

# --- Optional ---------------------------------------------------------------
# PDF receipts are rendered with headless Chrome. On Vercel this is handled by
# @sparticuz/chromium automatically. Locally, set this only if Chrome isn't
# found at one of the usual paths.
# CHROME_PATH="/usr/bin/google-chrome"
